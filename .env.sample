HIVE_CORE_URL=http://hivecore.famnit.upr.si:7777
HIVE_KEY=my-secret-key
CONCURRENT_REQUESTS=3

# ollama (default) or vllm
INFERENCE_BACKEND=ollama

# Ollama mode: docker (default) or external.
OLLAMA_MODE=docker

# Used when INFERENCE_BACKEND=ollama and OLLAMA_MODE=docker.
OLLAMA_PORT=11434
HIVE_OLLAMA_MODELS=/usr/share/ollama/.ollama/
GPU_PASSTHROUGH=-1

# Used when INFERENCE_BACKEND=ollama and OLLAMA_MODE=external.
# OLLAMA_URL=http://localhost:11434

# vLLM is always external from HiveNode's perspective.
# To use it, set INFERENCE_BACKEND=vllm and point one of these at the
# vLLM OpenAI-compatible server origin. HiveCore should send /v1/... paths.
# VLLM_URL=http://localhost:8000
# BACKEND_URL=http://localhost:8000

# Optional bearer token for vLLM requests.
# VLLM_API_KEY=token-abc123
# BACKEND_API_KEY=token-abc123

#INFLUX_HOST=url
#INFLUX_ORG=FAMNIT
#INFLUX_TOKEN=my-tokens
